@model List<SV22T1020570.Models.Sales.ShoppingCartItem>

@{
    decimal subtotal = Model.Sum(x => x.Quantity * x.SalePrice);

    decimal total = subtotal;
}

<!-- 🔥 NHỚ THÊM JQUERY -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="container py-5">

    <!-- 🔥 CLEAR CART -->
    <div class="text-end mb-3">
        <button class="btn btn-outline-danger" id="clearCart">
            Clear Cart
        </button>
    </div>

    <!-- TABLE -->
    <div class="table-responsive">
        <table class="table align-middle text-center">

            <thead>
                <tr>
                    <th>Products</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Handle</th>
                </tr>
            </thead>

            <tbody id="cartBody">

                @foreach (var item in Model)
                {
                    <tr data-id="@item.ProductID">

                        <!-- ✅ FIX IMAGE -->
                        <td>
                            <img src="~/images/products/@item.Photo"
                                 onerror="this.src='/img/nophoto.png'"
                                 style="width:80px;height:80px;object-fit:cover;">
                        </td>

                        <td>@item.ProductName</td>

                        <td class="price" data-price="@item.SalePrice.ToString("0")">
                            @item.SalePrice.ToString("N0")đ
                        </td>

                        <td>
                            <div class="input-group justify-content-center" style="width:120px;">
                                <button class="btn btn-light minus">-</button>

                                <input type="text"
                                       class="form-control text-center qty"
                                       value="@item.Quantity"
                                       readonly />

                                <button class="btn btn-light plus">+</button>
                            </div>
                        </td>

                        <td class="item-total">
                            @total.ToString("N0") đ
                        </td>

                        <td>
                            <button class="btn btn-danger delete">
                                <i class="fa fa-times"></i>
                            </button>
                        </td>

                    </tr>
                }

            </tbody>
        </table>
    </div>

    <!-- TOTAL -->
    <div class="row justify-content-end">
        <div class="col-md-4">
            <div class="bg-light p-4 rounded">

                <h4>Cart Total</h4>

                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <span id="subtotal">@subtotal</span>
                </div>

                <div class="d-flex justify-content-between">
                    <span>Shipping</span>
                    <span>Freeship</span>
                </div>

                <hr />

                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span id="total">@total</span>
                </div>

                <button class="btn btn-success w-100 mt-3" onclick="goCheckout()">
                    Payment
                </button>

            </div>
        </div>
    </div>
</div>

<script>

    // 🔥 EVENT DELEGATION (QUAN TRỌNG)
    $(document).on("click", ".plus", function () {
        let row = $(this).closest("tr");
        let id = row.data("id");
        let qty = parseInt(row.find(".qty").val()) + 1;

        updateCart(row, id, qty);
    });

    $(document).on("click", ".minus", function () {
        let row = $(this).closest("tr");
        let id = row.data("id");
        let qty = parseInt(row.find(".qty").val()) - 1;

        if (qty < 1) return;

        updateCart(row, id, qty);
    });

    // ❌ DELETE ITEM
    $(document).on("click", ".delete", function () {
        let row = $(this).closest("tr");
        let id = row.data("id");

        $.post("/Order/DeleteCartItem", { productId: id }, function (res) {
            if (res.code == 1) {
                row.remove();
                recalc();
            }
        });
    });

    // 🔥 CLEAR CART
    $("#clearCart").click(function () {
        if (!confirm("Xóa toàn bộ giỏ hàng?")) return;

        $.post("/Order/ClearCart", function (res) {
            if (res.code == 1) {
                $("#cartBody").html("");
                recalc();
            }
        });
    });

    // 🔥 UPDATE CART
    function updateCart(row, id, qty) {

        $.post("/Order/UpdateCart",
            { productId: id, quantity: qty },
            function (res) {

                if (res.code == 1) {

                    row.find(".qty").val(qty);

                    let price = parseFloat(row.find(".price").data("price"));
                    let total = price * qty;

                    row.find(".item-total").text( total.toFixed(2));

                    recalc();
                }
            });
    }

    // 🔥 RECALC
    function recalc() {

        let subtotal = 0;

        (".item-total").each(function () {
            subtotal += parseFloat($(this).text().replace(""));
        });

        
        let total = subtotal ;

        ("#subtotal").text( subtotal.toFixed(2));
        ("#total").text(total.toFixed(2));
    }

    // 🔥 CHECKOUT
    function goCheckout() {
        window.location = "/Order/Checkout";
    }

</script>