@model PagedResult<SV22T1020570.Models.Sales.OrderViewInfo>
@using SV22T1020570.Models.Sales

<div class="container mt-4">

    <div class="card mb-3 shadow-sm">
        <div class="card-body">

            <form id="formSearch"
                  method="get"
                  action="/Order/Search"
                  data-target="searchResult"
                  onsubmit="paginationSearch(event, this, 1)">

                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="PageSize" value="12" />

                <div class="row g-2">

                    <div class="col-md-5">
                        <input type="text" name="SearchValue"
                               class="form-control"
                               placeholder="Tìm đơn..." />
                    </div>

                    <div class="col-md-2">
                        <select name="Status"
                                class="form-select"
                                onchange="paginationSearch(null, document.getElementById('formSearch'), 1)">
                            <option value="0">--Trạng thái--</option>
                            <option value="1">New</option>
                            <option value="2">Accepted</option>
                            <option value="3">Shipping</option>
                            <option value="4">Completed</option>
                            <option value="-1">Cancelled</option>
                            <option value="-2">Rejected</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="DateFrom"
                               class="form-control"
                               onchange="paginationSearch(null, document.getElementById('formSearch'), 1)" />
                    </div>

                    <div class="col-md-2">
                        <input type="date" name="DateTo"
                               class="form-control"
                               onchange="paginationSearch(null, document.getElementById('formSearch'), 1)" />
                    </div>

                    <div class="col-md-1">
                        <button class="btn btn-primary w-100">
                            <i class="fa fa-search"></i>
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    <h3 class="fw-bold mb-3">My Orders</h3>

    <div id="searchResult"></div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        paginationSearch(null, document.getElementById("formSearch"), 1);
    });

    function paginationSearch(event, form, page) {

        if (event) event.preventDefault();

        form.querySelector("[name='Page']").value = page;

        const target = document.getElementById(form.dataset.target);

        target.style.opacity = 0.3;

        fetch(form.action + "?" + new URLSearchParams(new FormData(form)))
            .then(res => res.text())
            .then(html => {

                setTimeout(() => {
                    target.innerHTML = html;
                    target.style.opacity = 1;
                }, 150);

            });
    }
</script>