@model PagedResult<Product>
@{
    Layout = null;
}
<div class="row">

@foreach (var item in Model.DataItems)
{
    <div class="col-md-3 mb-4">

            <div class="card h-100 shadow-sm">

                <!-- IMAGE -->
                <img src="~/img/nophoto.png"
                     class="card-img-top"
                     style="height:200px; object-fit:cover;" />

                <!-- BODY -->
                <div class="card-body">

                    <h6 class="fw-bold">
                        @item.ProductName
                    </h6>

                    <p class="text-muted small">
                        @item.ProductDescription
                    </p>

                    <div class="fw-bold text-primary">
                        @item.Price.ToString("N0") đ
                    </div>

                </div>

                <!-- ACTION -->
                <div class="card-footer bg-white d-flex justify-content-between">

                    <a href="/Product/Detail/@item.ProductID"
                       class="btn btn-sm btn-outline-primary">
                        See more
                    </a>
                    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

                    <form method="post" action="/Order/AddToCart">
                        <input type="hidden" name="productId" value="@item.ProductID" />
                        <button type="button"
                                onclick="addCart(@item.ProductID)"
                                class="btn btn-success btn-sm">
                            + Cart
                        </button>
                    </form>

                </div>

            </div>

        </div>

        }

<!-- PAGINATION -->
<div class="card-footer">
    <ul class="pagination justify-content-center">
        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.IsCurrent)
            {
                <li class="page-item active">
                    <a class="page-link">@p.Page</a>
                </li>
            }
            else if (p.IsEllipsis)
            {
                <li class="page-item">
                    <a class="page-link">...</a>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                        @p.Page
                    </a>
                </li>
            }
        }

    </ul>
</div>


    <script>
        function addCart(productId) {

            let qty = document.getElementById("qty").value;

            $.post("/Order/AddToCart",
                {
                    productId: productId,
                    quantity: qty
                },
                function (res) {
                    if (res.code == 1) {
                        showToast("✔ Đã thêm vào giỏ hàng");
                    } else {
                        showToast(res.message, true);
                    }
                });
        }


        // 🔥 TOAST GIỮA MÀN HÌNH
        function showToast(msg, isError = false) {

            let toast = document.createElement("div");

            toast.innerHTML = msg;

            toast.style.position = "fixed";
            toast.style.top = "50%";
            toast.style.left = "50%";
            toast.style.transform = "translate(-50%, -50%) scale(0.9)";
            toast.style.background = isError ? "#dc3545" : "#28a745";
            toast.style.color = "#fff";
            toast.style.padding = "18px 30px";
            toast.style.borderRadius = "12px";
            toast.style.fontSize = "16px";
            toast.style.fontWeight = "500";
            toast.style.boxShadow = "0 10px 30px rgba(0,0,0,0.3)";
            toast.style.zIndex = "9999";
            toast.style.opacity = "0";
            toast.style.transition = "all 0.3s ease";

            document.body.appendChild(toast);

            // 🔥 animation vào
            setTimeout(() => {
                toast.style.opacity = "1";
                toast.style.transform = "translate(-50%, -50%) scale(1)";
            }, 50);

            // 🔥 biến mất
            setTimeout(() => {
                toast.style.opacity = "0";
                toast.style.transform = "translate(-50%, -50%) scale(0.9)";
            }, 1500);

            setTimeout(() => {
                toast.remove();
            }, 1800);
        }
    </script>
