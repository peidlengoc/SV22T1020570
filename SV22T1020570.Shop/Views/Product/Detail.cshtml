@model SV22T1020570.Models.Catalog.Product

<div class="container mt-5">

    <div class="row">

        <!-- IMAGE -->
        <div class="col-md-6">
            <div class="border rounded p-2">
                <img src="~/images/products/@Model.Photo"
                     onerror="this.src='/img/nophoto.png'"
                     class="img-fluid w-100"
                     style="object-fit:cover; height:450px;" />
            </div>
        </div>

        <!-- INFO -->
        <div class="col-md-6">

            <h3 class="fw-bold">@Model.ProductName</h3>

            <p class="text-muted">
                Category: @Model.CategoryName
            </p>

            <h4 class="text-success fw-bold">
                @Model.Price.ToString("N0") đ
            </h4>

            <div class="mb-3 text-warning">
                <i class="fa fa-star"></i>
                <i class="fa fa-star"></i>
                <i class="fa fa-star"></i>
                <i class="fa fa-star"></i>
                <i class="fa fa-star text-secondary"></i>
            </div>

            <p class="text-muted">
                @(string.IsNullOrWhiteSpace(Model.ProductDescription)
                                ? "Lorem ipsum dolor sit amet, consectetur adipiscing elit..."
                                : Model.ProductDescription)
            </p>

            <div class="d-flex align-items-center mb-3">
                <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">-</button>

                <input type="text" id="qty"
                       value="1"
                       class="form-control text-center mx-2"
                       style="width:60px;" />

                <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
            </div>

            <button type="button"
                    onclick="addCart(@Model.ProductID)"
                    class="btn btn-success px-4">
                <i class="fa fa-shopping-bag"></i> Add To Cart
            </button>

        </div>
    </div>

    <div class="mt-5">

        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active">Description</a>
            </li>
            <li class="nav-item">
                <a class="nav-link">Reviews</a>
            </li>
        </ul>

        <div class="p-3 border">

            <p>
                @(string.IsNullOrWhiteSpace(Model.ProductDescription)
                                ? "Lorem ipsum is simply dummy text..."
                                : Model.ProductDescription)
            </p>

            <div class="bg-light p-2">
                <strong>Unit:</strong> @Model.Unit
            </div>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function changeQty(val) {
        let qty = document.getElementById("qty");
        let newVal = parseInt(qty.value) + val;

        if (newVal < 1) newVal = 1;

        qty.value = newVal;
    }

    function addCart(productId) {

        let qty = document.getElementById("qty").value;

        $.post("/Order/AddToCart",
            {
                productId: productId,
                quantity: qty
            },
            function (res) {
                if (res.code == 1) {
                    showToast("✔ Đã thêm vào giỏ hàng");
                } else {
                    showToast(res.message, true);
                }
            });
    }

    function showToast(msg, isError = false) {

        let toast = document.createElement("div");

        toast.innerHTML = msg;

        toast.style.position = "fixed";
        toast.style.top = "50%";
        toast.style.left = "50%";
        toast.style.transform = "translate(-50%, -50%) scale(0.9)";
        toast.style.background = isError ? "#dc3545" : "#28a745";
        toast.style.color = "#fff";
        toast.style.padding = "18px 30px";
        toast.style.borderRadius = "12px";
        toast.style.fontSize = "16px";
        toast.style.fontWeight = "500";
        toast.style.boxShadow = "0 10px 30px rgba(0,0,0,0.3)";
        toast.style.zIndex = "9999";
        toast.style.opacity = "0";
        toast.style.transition = "all 0.3s ease";

        document.body.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = "1";
            toast.style.transform = "translate(-50%, -50%) scale(1)";
        }, 50);

        setTimeout(() => {
            toast.style.opacity = "0";
            toast.style.transform = "translate(-50%, -50%) scale(0.9)";
        }, 1500);

        setTimeout(() => {
            toast.remove();
        }, 1800);
    }
</script>