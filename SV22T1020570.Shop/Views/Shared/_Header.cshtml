<div class="container-fluid">

    <!-- TOPBAR -->
    <div class="topbar bg-primary d-none d-lg-block">
        <div class="container">
            <div class="d-flex justify-content-between">
                <div class="top-info ps-2">
                    <small class="text-white">LND Shop - Good Products Everyday</small>
                </div>
                <div class="top-link pe-2">
                    <small class="text-white">Freeship all bills</small>
                </div>
            </div>
        </div>
    </div>

    <!-- NAVBAR -->
    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-xl">

            <!-- LOGO -->
            <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                <h1 class="text-primary display-6">LND Shop</h1>
            </a>

            <!-- TOGGLE -->
            <button class="navbar-toggler py-2 px-3" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars text-primary"></span>
            </button>

            <div class="collapse navbar-collapse bg-white" id="navbarCollapse">

                <!-- MENU -->
                <div class="navbar-nav mx-auto">
                    <a asp-controller="Home" asp-action="Index" class="nav-item nav-link ">Home</a>

                    <a asp-controller="Product" asp-action="Index" class="nav-item nav-link">
                        Shopping
                    </a>

                    <a asp-controller="Order" asp-action="Index" class="nav-item nav-link">
                        My Order
                    </a>
                </div>

                <!-- ICON -->
                <div class="d-flex m-3 me-0">

                    <!-- CART -->
                    <a asp-controller="Order" asp-action="Cart" class="position-relative me-4 my-auto">
                        <i class="fa fa-shopping-bag fa-2x"></i>
                        <span class="position-absolute bg-secondary rounded-circle px-1"
                              style="top: -5px; left: 15px;"></span>
                    </a>

                    <!-- USER -->
                    <div class="dropdown my-auto">

                        <a class="nav-link dropdown-toggle text-dark"
                           href="javascript:void(0)"
                           id="userDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="fas fa-user fa-2x"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">

                            <li>
                                <a asp-controller="Account" asp-action="EditProfile" class="dropdown-item">
                                    <i class="fas fa-user-edit me-2"></i> Edit Profile
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Account" asp-action="ChangePassword" class="dropdown-item">
                                    <i class="fas fa-key me-2"></i> Change Password
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a asp-controller="Account" asp-action="Logout" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                                </a>
                            </li>

                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </div>
</div>